{
    "name": "tebim/lowestshippingcost",
    "description": "Displays the lowest possible delivery cost on the product page.",
    "type": "prestashop-module",
    "license": "AFL-3.0",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Recruitment Task"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "PrestaShop\\Module\\LowestShippingCost\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PrestaShop\\Module\\LowestShippingCost\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "preferred-install": "dist",
        "prepend-autoloader": false,
        "platform-check": false,
        "sort-packages": true
    }
}
